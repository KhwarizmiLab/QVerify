			missing_proof_count += 1
			results, rules_min, rules_max, rules_sum, loc_min, loc_max, loc_sum = _stub_results_from_spthy(
				spthy_path, proto_count, rules_min, rules_max, rules_sum, loc_min, loc_max, loc_sum
			)
			print('No proof file for "%s" (row still listed)' % os.path.basename(spthy_path))
			global_results.append(results)
			continue

		proof_file = proof_path
		print('Parsing "%s"' % proof_file)


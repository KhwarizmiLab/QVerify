			spthy_files += [
				os.path.join(dir_abs, file)
				for file in os.listdir(dir_abs)
				if file.endswith('.spthy')
			]
		except OSError as e:
			print('[Error] Cannot read directory "%s": %s' % (dir_abs, e))
			return None

	spthy_files.sort()
	spthy_files.reverse()

	for spthy_path in spthy_files:
		proto_count += 1
		proof_path = os.path.splitext(spthy_path)[0] + '.proof'
		theory_file = spthy_path

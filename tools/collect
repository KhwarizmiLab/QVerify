def to_timeformat(time):
	hours = int(time / 3600)
	time -= hours * 3600
	mins = int(time / 60)
	time  -= mins * 60
	secs = time

	decimals_for_secs = '0'
	if hours + mins == 0:
		decimals_for_secs = '2'

	if mins + hours > 0:
		if hours > 0:
			tt = str(hours) + 'h'\
						+ '{:02d}'.format(mins) + 'm'\
						+ ('{0:02.'+ decimals_for_secs + 'f}').format(secs) + 's'
		else:
			tt = str(mins) + 'm' + ('{0:02.'+ decimals_for_secs + 'f}').format(secs) + 's'
	else:
		tt = ('{0:.'+ decimals_for_secs + 'f}').format(secs) + 's'
	
	return tt

def to_secs(time):
	t = 0.0
	if 'h' in time:
		t += int(time.split('h')[0]) * 3600
		time = time.split('h')[1]
	if 'm' in time:
		t += int(time.split('m')[0]) * 60
		time = time.split('m')[1]
	t += float(time.split('s')[0])
	return t


def _theory_name_from_spthy(spthy_path):
	"""Theory line in .spthy may be 'theory Name' with begin on the next lines."""
	with open(spthy_path, encoding='utf-8', errors='replace') as f:
		for line in f:
			line = line.strip()
			if not line or line.startswith('//'):
				continue
			m = re.match(r'^theory (\w+) begin$', line)
			if m:
				return m.group(1)
			m = re.match(r'^theory (\w+)$', line)
			if m:
				return m.group(1)
	return os.path.basename(spthy_path).replace('.spthy', '')


def _stub_results_from_spthy(spthy_path, proto_count, rules_min, rules_max, rules_sum, loc_min, loc_max, loc_sum):
	lines = open(spthy_path, encoding='utf-8', errors='replace').readlines()
	theory_name = _theory_name_from_spthy(spthy_path)
	rule_names = []
	for line in lines:
		m = re.match(RULE_HEADER_SPTHY_REGEX, line)
		if m:
			rule_names.append(m.group(1))
	num_rules = len(rule_names)
	if num_rules < rules_min:
		rules_min = num_rules
	if num_rules > rules_max:
		rules_max = num_rules
	rules_sum += num_rules
	loc = len(lines)
	if loc < loc_min:
		loc_min = loc
	if loc > loc_max:
		loc_max = loc
	loc_sum += loc
	return {
		'No.': str(proto_count),
		'Verified': 'No',
		'Theory': theory_name,
		'Theory file': spthy_path,
		'Proof file': '(missing)',
		'Rules': str(num_rules),
		'LoC': str(loc),
		'Time': NA_HTML,
	}, rules_min, rules_max, rules_sum, loc_min, loc_max, loc_sum


def create_html_code(directories, columns, tex_add):


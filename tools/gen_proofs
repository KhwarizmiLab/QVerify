#!/bin/sh

# Define variables
TAMARIN=./tools/tamarin-prover
TAMARIN_FLAGS=

MANIFEST=./_output/.spthy_manifest

# List .spthy paths without globbing ./_output (Docker Desktop macOS: EPERM on readdir).
list_spthy_paths() {
    if [ -f "$MANIFEST" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            [ -z "$line" ] && continue
            echo "$line"
        done <"$MANIFEST"
        return
    fi
    for f in ./_output/*.spthy; do
        [ -f "$f" ] && echo "$f"
    done
}

# Prove file function
prove_file() {
    file="$1"
    proof_file=$(echo "$file" | sed 's/\.spthy$/.proof/')

    # Skip if proof already exists
    if [ -f "$proof_file" ]; then
        echo "Proof file already exists, continuing with other operations..."
        return 0
    fi

    # Print date and time for monitoring
    echo "Analysis started on $(date '+%Y-%m-%d at %H:%M:%S') for file: ${file}"

    # Capture Tamarin stdout to /tmp: Docker Desktop macOS bind mounts can refuse creating
    # some ./_output/*.tmp names next to .spthy (ENOENT) while mktemp under /tmp works.
    tmp_file=$(mktemp /tmp/qverify_tamarin.XXXXXX)

    # Run Tamarin
    CMD="$TAMARIN --prove --derivcheck-timeout=0 -c=100 ${file} $TAMARIN_FLAGS --output=${proof_file}"
    echo "$CMD"
    eval "$CMD" >"$tmp_file" 2>&1

    echo "Appending results from $tmp_file to $proof_file..."
    sed -n "/^==============================================================================/,\$p" "$tmp_file" >>"$proof_file"
    echo >>"$proof_file"
    echo >>"$proof_file"

    # Keep full output for inspection, remove .tmp
    full_output=$(echo "$file" | sed 's/\.spthy$/.full_output/')
    mv "$tmp_file" "$full_output"
    echo "Prove completed for file: ${file}."
    return 0
}

# Main logic
if [ ! -d "./_output" ]; then
    echo "Directory './_output/' not found!"
    exit 1
fi

# Avoid find(1) on ./_output: Docker Desktop macOS bind mounts can return EPERM on find.
FILES=$(list_spthy_paths | sort -r)
if [ -z "$FILES" ]; then
    echo "No .spthy files found in './_output/' directory."
    exit 0
fi

TOTAL=0
NEED=0
for f in $FILES; do
    [ -f "$f" ] || continue
    TOTAL=$((TOTAL + 1))
    pf=$(echo "$f" | sed 's/\.spthy$/.proof/')
    [ -f "$pf" ] || NEED=$((NEED + 1))
done
echo "gen_proofs: $TOTAL theory file(s); $NEED still need a .proof (others are skipped)."

for file in $FILES; do
    prove_file "$file"
done

MISSING_END=0
for f in $FILES; do
    [ -f "$f" ] || continue
    pf=$(echo "$f" | sed 's/\.spthy$/.proof/')
    [ -f "$pf" ] || MISSING_END=$((MISSING_END + 1))
done
if [ "$MISSING_END" -gt 0 ]; then
    echo "gen_proofs: INCOMPLETE — $MISSING_END theory file(s) still have no .proof (interrupt or Tamarin error)."
    if [ -z "$GEN_PROOFS_ALLOW_PARTIAL" ]; then
        exit 1
    fi
else
    echo "gen_proofs: complete — all $TOTAL theories have .proof files."
fi
